<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import PocketBase from "pocketbase";
  import { POCKETBASE_URL } from "../utils/pocketbase-config";

  gsap.registerPlugin(ScrollTrigger);

  const pb = new PocketBase(POCKETBASE_URL);

  // Animation au scroll (Intersection Observer)
  const observerOptions = {
    threshold: 0.2,
    rootMargin: "0px 0px -50px 0px",
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        setTimeout(() => {
          entry.target.classList.add("animate-fade-in");
        }, 50);
        observer.unobserve(entry.target);
      }
    });
  }, observerOptions);

  // Observer tous les éléments avec la classe scroll-reveal
  document.addEventListener("DOMContentLoaded", () => {
    const elements = document.querySelectorAll(".scroll-reveal");
    elements.forEach((el, index) => {
      if (el instanceof HTMLElement) {
        el.style.transitionDelay = `${index * 0.1}s`;
      }
      observer.observe(el);
    });

    // Smooth scroll pour les liens d'ancrage
    document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
      anchor.addEventListener("click", function (e: Event) {
        e.preventDefault();
        const href = (e.currentTarget as HTMLAnchorElement).getAttribute(
          "href",
        );
        if (href) {
          const target = document.querySelector(href);
          if (target) {
            target.scrollIntoView({
              behavior: "smooth",
              block: "start",
            });
          }
        }
      });
    });

    // Animation des particules de fond (optionnel - effet spatial)
    createFloatingParticles();

    // Animations et compteurs de la section À propos
    initAboutSection();

    // Animations de la section compétences
    initSkillsSection();

    // Animations de la section contact
    initContactSection();
  });

  // Fonction pour créer des particules flottantes
  function createFloatingParticles() {
    const hero = document.querySelector("#hero");
    if (!hero) return;

    for (let i = 0; i < 20; i++) {
      const particle = document.createElement("div");
      particle.className =
        "absolute w-1 h-1 rounded-full bg-primary-pink/30 animate-float";
      particle.style.left = `${Math.random() * 100}%`;
      particle.style.top = `${Math.random() * 100}%`;
      particle.style.animationDelay = `${Math.random() * 6}s`;
      particle.style.animationDuration = `${6 + Math.random() * 4}s`;
      hero.appendChild(particle);
    }
  }

  function initAboutSection() {
    const aboutSection = document.querySelector("#about");
    if (!aboutSection) return;

    const label = aboutSection.querySelector(
      "[data-about-label]",
    ) as HTMLElement | null;
    const titleLine1 = aboutSection.querySelector(
      "[data-about-line-1]",
    ) as HTMLElement | null;
    const titleLine2 = aboutSection.querySelector(
      "[data-about-line-2]",
    ) as HTMLElement | null;
    const paragraph = aboutSection.querySelector(
      "[data-about-paragraph]",
    ) as HTMLElement | null;
    const button = aboutSection.querySelector(
      "[data-about-button]",
    ) as HTMLElement | null;
    const pills = gsap.utils.toArray<HTMLElement>("[data-about-pill]");
    const statsColumn = aboutSection.querySelector(
      "[data-about-stats]",
    ) as HTMLElement | null;
    const stats = gsap.utils.toArray<HTMLElement>("[data-about-stat]");

    if (label && titleLine1 && titleLine2 && paragraph && button) {
      const isMobile = window.matchMedia("(max-width: 768px)").matches;
      const textTimeline = gsap.timeline({
        scrollTrigger: {
          trigger: aboutSection,
          start: "top 80%",
          once: true,
        },
      });

      textTimeline.from(
        label,
        {
          autoAlpha: 0,
          duration: 0.45,
          ease: "power2.out",
        },
        0,
      );

      if (isMobile) {
        textTimeline.from(
          [titleLine1, titleLine2],
          {
            autoAlpha: 0,
            duration: 0.6,
            stagger: 0.12,
            ease: "power2.out",
          },
          0.1,
        );
      } else {
        textTimeline.from(
          titleLine1,
          {
            x: -40,
            autoAlpha: 0,
            duration: 0.7,
            ease: "power3.out",
          },
          0.1,
        );

        textTimeline.from(
          titleLine2,
          {
            x: -40,
            autoAlpha: 0,
            duration: 0.7,
            ease: "power3.out",
          },
          0.25,
        );
      }

      textTimeline.from(
        paragraph,
        {
          autoAlpha: 0,
          duration: 0.6,
          ease: "power2.out",
        },
        0.3,
      );

      if (pills.length > 0) {
        textTimeline.from(
          pills,
          {
            autoAlpha: 0,
            duration: 0.45,
            stagger: 0.1,
            ease: "power2.out",
          },
          0.4,
        );
      }

      textTimeline.from(
        button,
        {
          autoAlpha: 0,
          duration: 0.6,
          ease: "power2.out",
        },
        0.5,
      );
    }

    if (statsColumn && stats.length > 0) {
      ScrollTrigger.create({
        trigger: statsColumn,
        start: "top 80%",
        once: true,
        onEnter: () => {
          stats.forEach((stat, index) => {
            const targetValue = Number(stat.dataset.target ?? "0");
            const suffix = stat.dataset.suffix ?? "";
            const counter = { val: 0 };

            gsap.to(counter, {
              val: targetValue,
              duration: 2,
              delay: index * 0.2,
              ease: "power2.out",
              onUpdate: () => {
                stat.textContent = `${Math.round(counter.val)}${suffix}`;
              },
            });
          });
        },
      });
    }
  }

  function initSkillsSection() {
    const skillsSection = document.querySelector("#skills");
    if (!skillsSection) return;

    const heading = skillsSection.querySelector(
      "[data-skills-heading]",
    ) as HTMLElement | null;
    const progressBlock = skillsSection.querySelector(
      "[data-skills-progress]",
    ) as HTMLElement | null;

    if (heading) {
      gsap.from(heading, {
        x: -40,
        autoAlpha: 0,
        duration: 0.8,
        ease: "power2.out",
        scrollTrigger: {
          trigger: heading,
          start: "top 80%",
          once: true,
        },
      });
    }

    if (!progressBlock) return;

    const skillRows = Array.from(
      progressBlock.querySelectorAll<HTMLElement>("[data-skill-row]"),
    );

    skillRows.forEach((row, index) => {
      const barElement = row.querySelector(
        "[data-skill-bar]",
      ) as HTMLElement | null;
      const valueElement = row.querySelector(
        "[data-skill-value]",
      ) as HTMLElement | null;
      const targetValue = Number(row.dataset.target ?? "0");
      const delay = index * 0.2;

      if (barElement) {
        gsap.to(barElement, {
          width: `${targetValue}%`,
          duration: 1.5,
          ease: "power2.out",
          delay,
          scrollTrigger: {
            trigger: progressBlock,
            start: "top 80%",
            once: true,
          },
        });
      }

      if (valueElement) {
        const counter = { val: 0 };

        gsap.to(counter, {
          val: targetValue,
          duration: 1.5,
          ease: "power2.out",
          delay,
          scrollTrigger: {
            trigger: progressBlock,
            start: "top 80%",
            once: true,
          },
          onUpdate: () => {
            valueElement.textContent = `${Math.round(counter.val)}%`;
          },
        });
      }
    });
  }

  function initContactSection() {
    const contactSection = document.querySelector("#contact");
    if (!contactSection) return;

    // Animations d'entrée
    const header = document.querySelector("#contact-header");
    if (header) {
      gsap.fromTo(
        header,
        { opacity: 0, y: -20 },
        {
          opacity: 1,
          y: 0,
          duration: 0.8,
          ease: "power2.out",
          scrollTrigger: {
            trigger: contactSection,
            start: "top 80%",
            once: true,
          },
        },
      );
    }

    const infoCol = document.querySelector("#contact-info");
    const contactItems = gsap.utils.toArray<HTMLElement>(".contact-item");
    if (infoCol) {
      const infoTl = gsap.timeline({
        scrollTrigger: {
          trigger: contactSection,
          start: "top 75%",
          once: true,
        },
      });

      infoTl.fromTo(
        infoCol,
        { x: -40, opacity: 0 },
        { x: 0, opacity: 1, duration: 0.8, ease: "power2.out" },
      );

      if (contactItems.length > 0) {
        infoTl.fromTo(
          contactItems,
          { x: -20, opacity: 0 },
          { x: 0, opacity: 1, duration: 0.5, stagger: 0.1, ease: "power2.out" },
          "-=0.4",
        );
      }
    }

    const formWrapper = document.querySelector("#contact-form-wrapper");
    if (formWrapper) {
      gsap.fromTo(
        formWrapper,
        { x: 40, opacity: 0 },
        {
          x: 0,
          opacity: 1,
          duration: 0.8,
          delay: 0.1,
          ease: "power2.out",
          scrollTrigger: {
            trigger: contactSection,
            start: "top 75%",
            once: true,
          },
        },
      );
    }

    // Validation du formulaire
    const form = document.getElementById(
      "contact-form",
    ) as HTMLFormElement | null;
    if (form) {
      form.addEventListener("submit", async (e) => {
        e.preventDefault();

        const fields = [
          { id: "input-prenom", required: true },
          { id: "input-nom", required: true },
          { id: "input-email", required: true },
          { id: "input-message", required: true },
        ];

        let hasError = false;

        fields.forEach(({ id, required }) => {
          const el = document.getElementById(id) as
            | HTMLInputElement
            | HTMLTextAreaElement
            | null;
          if (el && required && !el.value.trim()) {
            hasError = true;
            el.classList.add("border-red-500/60", "bg-red-500/5");
            const wrapper = el.closest(".field-wrapper");
            gsap.to(wrapper || el, {
              keyframes: { x: [-8, 8, -6, 6, -4, 4, 0] },
              duration: 0.4,
              ease: "power2.out",
            });

            el.addEventListener(
              "input",
              () => {
                el.classList.remove("border-red-500/60", "bg-red-500/5");
              },
              { once: true },
            );
          }
        });

        const emailEl = document.getElementById(
          "input-email",
        ) as HTMLInputElement | null;
        const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        if (emailEl && emailEl.value && !emailRegex.test(emailEl.value)) {
          hasError = true;
          emailEl.classList.add("border-red-500/60", "bg-red-500/5");
          const wrapper = emailEl.closest(".field-wrapper");
          gsap.to(wrapper || emailEl, {
            keyframes: { x: [-8, 8, -6, 6, 0] },
            duration: 0.4,
            ease: "power2.out",
          });
        }

        if (!hasError) {
          const submitBtn = document.getElementById(
            "btn-submit",
          ) as HTMLButtonElement | null;
          const originalBtnContent = submitBtn ? submitBtn.innerHTML : "";

          if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.innerHTML = `
              <span class="relative z-10 flex items-center justify-center gap-2">
                <svg class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                  <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                  <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
                Envoi en cours...
              </span>
            `;
          }

          const formData = {
            prenom: (
              document.getElementById("input-prenom") as HTMLInputElement
            ).value,
            nom: (document.getElementById("input-nom") as HTMLInputElement)
              .value,
            email: (document.getElementById("input-email") as HTMLInputElement)
              .value,
            telephone:
              (document.getElementById("input-tel") as HTMLInputElement)
                .value || "",
            sujet: "autre",
            message: (
              document.getElementById("input-message") as HTMLTextAreaElement
            ).value,
            statut: "nouveau",
          };

          try {
            await pb.collection("messages_contact").create(formData);
            showSuccessState();
          } catch (error) {
            console.error("Erreur lors de l'envoi:", error);
            alert(
              "Une erreur s'est produite lors de l'envoi du message. Veuillez réessayer.",
            );
            if (submitBtn) {
              submitBtn.disabled = false;
              submitBtn.innerHTML = originalBtnContent;
            }
          }
        }
      });
    }
  }

  function showSuccessState() {
    const form = document.getElementById("contact-form");
    if (!form) return;

    gsap.to(form, {
      opacity: 0,
      y: -20,
      duration: 0.4,
      ease: "power2.in",
      onComplete: () => {
        form.innerHTML = `
					<div id="success-message" class="flex flex-col items-center justify-center text-center py-12 gap-6">
						<div id="success-icon" class="w-20 h-20 rounded-full bg-green-500/10 border border-green-500/30 flex items-center justify-center">
							<svg class="w-10 h-10 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
							</svg>
						</div>
						<div>
							<h3 class="text-2xl font-bold text-white mb-2">Message envoyé !</h3>
							<p class="text-gray-400 text-sm">Merci pour ton message. Je te réponds sous 24h.</p>
						</div>
						<button id="reset-form" type="button" class="text-sm text-gray-500 hover:text-primary-pink transition-colors underline underline-offset-4">
							Envoyer un autre message
						</button>
					</div>
				`;

        gsap.fromTo(
          form,
          { opacity: 0, y: 20 },
          { opacity: 1, y: 0, duration: 0.5, ease: "power2.out" },
        );

        gsap.fromTo(
          "#success-icon",
          { scale: 0, opacity: 0 },
          {
            scale: 1,
            opacity: 1,
            duration: 0.6,
            delay: 0.2,
            ease: "back.out(1.7)",
          },
        );

        const resetBtn = document.getElementById("reset-form");
        if (resetBtn) {
          resetBtn.addEventListener("click", () => {
            location.reload();
          });
        }
      },
    });
  }

  // Effet de parallaxe léger sur les cercles de fond
  window.addEventListener("scroll", () => {
    const circles = document.querySelectorAll(".bg-circle");
    const scrolled = window.pageYOffset;
    const maxScroll =
      document.documentElement.scrollHeight - window.innerHeight;

    circles.forEach((circle, index) => {
      const speed = 0.3 + index * 0.05; // Réduire la vitesse du parallaxe
      const movement = Math.min(scrolled * speed, maxScroll * speed); // Limiter le mouvement
      (circle as HTMLElement).style.transform = `translateY(${movement}px)`;
    });
  });

  // Effet de machine à écrire
  const text = "Designer graphique";
  const typewriterElement = document.getElementById("typewriter");
  const cursorElement = document.getElementById("cursor");
  let charIndex = 0;
  let isDeleting = false;

  function typeWriter() {
    if (!typewriterElement) return;

    if (!isDeleting && charIndex < text.length) {
      // Écriture
      typewriterElement.textContent += text.charAt(charIndex);
      charIndex++;
      setTimeout(typeWriter, 100 + Math.random() * 100); // Vitesse variable pour effet réaliste
    } else if (!isDeleting && charIndex === text.length) {
      // Pause à la fin
      isDeleting = true;
      setTimeout(typeWriter, 2000);
    } else if (isDeleting && charIndex > 0) {
      // Effacement
      typewriterElement.textContent = text.substring(0, charIndex - 1);
      charIndex--;
      setTimeout(typeWriter, 50);
    } else if (isDeleting && charIndex === 0) {
      // Recommencer
      isDeleting = false;
      setTimeout(typeWriter, 500);
    }
  }

  // Démarrer l'effet au chargement
  typeWriter();
</script>

<style>
  /* Animation pour les particules */
  @keyframes float {
    0%,
    100% {
      transform: translateY(0) translateX(0);
    }
    25% {
      transform: translateY(-20px) translateX(10px);
    }
    50% {
      transform: translateY(-40px) translateX(-10px);
    }
    75% {
      transform: translateY(-20px) translateX(5px);
    }
  }

  /* Animation du curseur clignotant */
  @keyframes blink {
    0%,
    50% {
      opacity: 1;
    }
    51%,
    100% {
      opacity: 0;
    }
  }

  @keyframes marquee-left {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @keyframes marquee-right {
    0% {
      transform: translateX(-50%);
    }
    100% {
      transform: translateX(0);
    }
  }

  .animate-marquee-left {
    animation: marquee-left 25s linear infinite;
  }

  .animate-marquee-right {
    animation: marquee-right 25s linear infinite;
  }

  .animate-marquee-left:hover,
  .animate-marquee-right:hover {
    animation-play-state: paused;
  }

  .project-desc-clamp {
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    overflow: hidden;
  }

  @media (hover: none) and (pointer: coarse) {
    .project-hover-overlay {
      opacity: 1 !important;
      transform: translateY(0) !important;
    }
  }

  .animate-blink {
    animation: blink 0.8s infinite;
  }
</style>
