---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Enzo Locatelli - Designer Graphique">
  <!-- Hero Section -->
  <section
    id="hero"
    class="min-h-screen flex items-center px-4 py-20 relative overflow-hidden"
  >
    <div class="max-w-7xl mx-auto w-full">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <!-- Texte à gauche -->
        <div class="animate-fade-in text-left">
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6">
            <span class="block text-white mb-2">Salut ! moi c'est</span>
            <span class="neon-pink text-5xl md:text-6xl lg:text-7xl"
              >Enzo Locatelli</span
            >
          </h1>

          <h2 class="text-2xl md:text-3xl mb-6">
            <span class="text-white">Et je suis</span><br />
            <span id="typewriter" class="text-primary-pink font-bold"></span>
            <span id="cursor" class="text-primary-pink font-bold animate-blink"
              >|</span
            >
          </h2>
          <p
            class="text-base md:text-lg leading-relaxed text-gray-300 mb-8 max-w-xl"
          >
            je crée des visuels modernes et percutants pour donner vie aux
            idées. Passionné par le design numérique, j’aime transformer une
            simple idée en une identité forte et mémorable. Mon objectif :
            allier créativité et clarté pour concevoir des projets qui marquent
          </p>
          <!-- Icônes sociales -->
          <div class="flex gap-4 mb-8">
            <a
              href="https://www.linkedin.com/in/enzo-locatelli-a414b2337"
              target="_blank"
              class="w-12 h-12 flex items-center justify-center rounded-lg bg-primary-pink/20 hover:bg-primary-pink transition-all hover:scale-110 btn-neon"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-6 w-6 text-primary-pink hover:text-white"
                fill="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
                ></path>
              </svg>
            </a>
            <a
              href="https://www.tiktok.com/@romance.wrld?lang=fr"
              target="_blank"
              class="w-12 h-12 flex items-center justify-center rounded-lg bg-primary-pink/20 hover:bg-primary-pink transition-all hover:scale-110 btn-neon"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-6 w-6 text-primary-pink hover:text-white"
                fill="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"
                ></path>
              </svg>
            </a>
          </div>

          <!-- Bouton télécharger CV -->
          <a
            href="/CV.pdf"
            class="btn btn-primary btn-lg btn-neon inline-flex items-center gap-2"
          >
            Télécharger mon CV
          </a>
        </div>

        <!-- Photo à droite -->
        <div
          class="relative animate-zoom-in flex justify-center md:justify-end"
        >
          <div class="relative">
            <div
              class="absolute inset-0 rounded-full bg-gradient-to-br from-primary-pink to-primary-blue blur-3xl opacity-60 animate-pulse-glow"
            >
            </div>
            <div
              class="relative w-72 h-72 md:w-96 md:h-96 rounded-full bg-gradient-to-br from-primary-pink via-purple-600 to-primary-blue p-1"
            >
              <div
                class="w-full h-full rounded-full bg-primary-pink overflow-hidden flex items-center justify-center"
              >
                <!-- Remplacez par votre vraie photo -->
                <div
                  class="w-full h-full rounded-full bg-gradient-to-br from-gray-800 to-gray-900 flex items-center justify-center text-8xl font-bold text-white/30"
                >
                  <!-- mettre une photo -->
                  <img
                    src="/pp-landingpage.webp"
                    alt="Photo de Enzo Locatelli"
                    class="w-full h-full object-cover"
                  />
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- À propos de moi -->
  <section id="about" class="py-32 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="relative grid grid-cols-1 gap-16 md:grid-cols-2 lg:gap-20">
        <div
          class="pointer-events-none absolute left-1/2 top-0 hidden h-full w-px -translate-x-1/2 bg-gradient-to-b from-transparent via-primary-pink/40 to-transparent md:block"
          aria-hidden="true"
        >
        </div>

        <div class="flex flex-col items-start">
          <p
            data-about-label
            class="text-sm uppercase tracking-widest text-white opacity-50"
          >
            À PROPOS
          </p>

          <h2
            class="mt-6 text-4xl font-bold leading-tight md:text-5xl lg:text-6xl"
          >
            <span data-about-line-1 class="block text-white">Je transforme</span
            >
            <span data-about-line-2 class="block neon-pink"
              >les idées en design</span
            >
          </h2>

          <p
            data-about-paragraph
            class="mt-6 max-w-xl text-base leading-relaxed text-gray-300 md:text-lg"
          >
            Étudiant en MMI, je conçois des visuels modernes qui allient
            créativité et stratégie. Photoshop, Figma, Illustrator - j'aime
            transformer une idée brute en identité visuelle forte.
          </p>

          <div
            class="mt-8 flex flex-wrap items-center gap-y-3 text-sm text-gray-200 md:text-base"
          >
            <span data-about-pill class="inline-flex items-center gap-2">
              <span class="h-2.5 w-2.5 rounded-full bg-primary-pink"></span>
              Design graphique
            </span>
            <span class="mx-3 text-gray-500">·</span>
            <span data-about-pill class="inline-flex items-center gap-2">
              <span class="h-2.5 w-2.5 rounded-full bg-primary-blue"></span>
              UX/UI
            </span>
            <span class="mx-3 text-gray-500">·</span>
            <span data-about-pill class="inline-flex items-center gap-2">
              <span class="h-2.5 w-2.5 rounded-full bg-[#7c3aed]"></span>
              Communication
            </span>
          </div>

          <a
            data-about-button
            href="/A-propos"
            class="btn btn-primary btn-lg btn-neon mt-12 inline-flex"
          >
            Découvrir plus
          </a>
        </div>

        <div data-about-stats class="relative">
          <div class="grid grid-cols-3 gap-4 md:flex md:flex-col">
            <div
              class="rounded-2xl border border-white/10 bg-gray-900/60 p-4 backdrop-blur-sm transition-all duration-300 ease-out hover:scale-[1.02] hover:border-primary-pink/40 md:p-6"
            >
              <div class="flex items-center gap-3">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-5 w-5 shrink-0 text-[#d019d0]"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.8"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M8 2v3m8-3v3M3.5 9.5h17M5 5.5h14A1.5 1.5 0 0120.5 7v12A1.5 1.5 0 0119 20.5H5A1.5 1.5 0 013.5 19V7A1.5 1.5 0 015 5.5z"
                  ></path>
                </svg>
                <p class="text-[11px] text-gray-400 md:text-sm">
                  Années d'expérience
                </p>
              </div>
              <div class="mt-4">
                <span
                  data-about-stat
                  data-target="2"
                  class="text-3xl font-bold leading-none text-[#d019d0] md:text-5xl"
                  >0</span
                >
              </div>
            </div>

            <div
              class="rounded-2xl border border-white/10 bg-gray-900/60 p-4 backdrop-blur-sm transition-all duration-300 ease-out hover:scale-[1.02] hover:border-primary-pink/40 md:p-6"
            >
              <div class="flex items-center gap-3">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-5 w-5 shrink-0 text-[#1974d1]"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.8"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M3.5 6.5A1.5 1.5 0 015 5h4l2 2h8A1.5 1.5 0 0120.5 8.5v10A1.5 1.5 0 0119 20H5a1.5 1.5 0 01-1.5-1.5v-12z"
                  ></path>
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M7 10h10M7 13h7"></path>
                </svg>
                <p class="text-[11px] text-gray-400 md:text-sm">
                  Projets réalisés
                </p>
              </div>
              <div class="mt-4">
                <span
                  data-about-stat
                  data-target="15"
                  data-suffix="+"
                  class="text-3xl font-bold leading-none text-[#1974d1] md:text-5xl"
                  >0+</span
                >
              </div>
            </div>

            <div
              class="rounded-2xl border border-white/10 bg-gray-900/60 p-4 backdrop-blur-sm transition-all duration-300 ease-out hover:scale-[1.02] hover:border-primary-pink/40 md:p-6"
            >
              <div class="flex items-center gap-3">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-5 w-5 shrink-0 text-[#7c3aed]"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.8"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M15 7l2-2 2 2-2 2m-2-2l-2 2m2-2l-3.5 3.5m-6 6l3-3m-4.5 1.5l2 2a1.5 1.5 0 002.12 0l8.88-8.88a1.5 1.5 0 000-2.12l-2-2a1.5 1.5 0 00-2.12 0L4.5 13.38a1.5 1.5 0 000 2.12z"
                  ></path>
                </svg>
                <p class="text-[11px] text-gray-400 md:text-sm">
                  Outils maîtrisés
                </p>
              </div>
              <div class="mt-4">
                <span
                  data-about-stat
                  data-target="8"
                  class="text-3xl font-bold leading-none text-[#7c3aed] md:text-5xl"
                  >0</span
                >
              </div>
            </div>
          </div>

          <div
            class="mt-4 rounded-xl border border-primary-pink/30 bg-primary-pink/10 p-4"
          >
            <div class="flex items-center gap-2 text-sm text-white">
              <span class="h-2.5 w-2.5 rounded-full bg-green-400 animate-pulse"
              ></span>
              Disponible pour une collaboration
            </div>
            <p class="mt-1 text-xs text-gray-300">Alternance · Projet</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Mes compétences -->
  <section id="skills" class="py-32 px-4">
    <div class="max-w-6xl mx-auto">
      <div data-skills-heading class="max-w-3xl">
        <p class="text-sm uppercase tracking-widest text-white opacity-40">
          MES COMPÉTENCES
        </p>
        <h2 class="mt-4 text-5xl font-bold text-white md:text-6xl">
          Mon arsenal <span class="neon-pink">créatif</span>
        </h2>
        <p class="mt-3 text-base text-gray-500">
          Les outils et savoir-faire que j'utilise au quotidien
        </p>
      </div>

      <div class="relative mt-16 overflow-hidden">
        <div
          class="absolute inset-y-0 left-0 z-10 w-20 bg-gradient-to-r from-[#050510] to-transparent"
        >
        </div>
        <div
          class="absolute inset-y-0 right-0 z-10 w-20 bg-gradient-to-l from-[#050510] to-transparent"
        >
        </div>

        <div class="flex flex-col gap-4">
          <div
            class="flex w-fit items-center whitespace-nowrap animate-marquee-left"
          >
            {
              [
                { nom: "Figma", logo: "/logos/figma.svg" },
                { nom: "Photoshop", logo: "/logos/photoshop.svg" },
                { nom: "Illustrator", logo: "/logos/illustrator.svg" },
                { nom: "Premiere Pro", logo: "/logos/premiere.svg" },
                { nom: "VS Code", logo: "/logos/vscode.svg" },
                { nom: "Astro", logo: "/logos/astro.jpg" },
                { nom: "TailwindCSS", logo: "/logos/tailwind.svg" },
                { nom: "Figma", logo: "/logos/figma.svg" },
                { nom: "Photoshop", logo: "/logos/photoshop.svg" },
                { nom: "Illustrator", logo: "/logos/illustrator.svg" },
                { nom: "Premiere Pro", logo: "/logos/premiere.svg" },
                { nom: "VS Code", logo: "/logos/vscode.svg" },
                { nom: "Astro", logo: "/logos/astro.jpg" },
                { nom: "TailwindCSS", logo: "/logos/tailwind.svg" },
              ].map((item) => (
                <div class="mx-2 inline-flex w-max shrink-0 items-center gap-3 whitespace-nowrap rounded-xl border border-white/10 bg-gray-900/80 px-3 py-2.5 text-xs transition-all duration-200 hover:scale-105 hover:border-primary-pink/50 md:px-5 md:py-3 md:text-sm">
                  <img
                    src={item.logo}
                    alt={`Logo ${item.nom}`}
                    class="h-5 w-5 shrink-0 object-contain md:h-6 md:w-6"
                    loading="lazy"
                    decoding="async"
                  />
                  <span class="whitespace-nowrap font-medium leading-none text-gray-300">
                    {item.nom}
                  </span>
                </div>
              ))
            }
          </div>

          <div
            class="flex w-fit items-center whitespace-nowrap animate-marquee-right"
          >
            {
              [
                { nom: "After Effects", logo: "/logos/after-effects.svg" },
                { nom: "Figma", logo: "/logos/figma.svg" },
                { nom: "GitHub", logo: "/logos/github.svg" },
                { nom: "Claude", logo: "/logos/claude.svg" },
                { nom: "ChatGPT", logo: "/logos/chatgpt.svg" },
                { nom: "Gemini", logo: "/logos/gemini.svg" },
                { nom: "JavaScript", logo: "/logos/javascript.svg" },
                { nom: "CSS", logo: "/logos/html-css.svg" },
                { nom: "HTML", logo: "/logos/html-css.svg" },
                { nom: "After Effects", logo: "/logos/after-effects.svg" },
                { nom: "Figma", logo: "/logos/figma.svg" },
                { nom: "GitHub", logo: "/logos/github.svg" },
                { nom: "JavaScript", logo: "/logos/javascript.svg" },
                { nom: "CSS", logo: "/logos/html-css.svg" },
                { nom: "HTML", logo: "/logos/html-css.svg" },
              ].map((item) => (
                <div class="mx-2 inline-flex w-max shrink-0 items-center gap-3 whitespace-nowrap rounded-xl border border-white/10 bg-gray-900/80 px-3 py-2.5 text-xs transition-all duration-200 hover:scale-105 hover:border-primary-pink/50 md:px-5 md:py-3 md:text-sm">
                  <img
                    src={item.logo}
                    alt={`Logo ${item.nom}`}
                    class="h-5 w-5 shrink-0 object-contain md:h-6 md:w-6"
                    loading="lazy"
                    decoding="async"
                  />
                  <span class="whitespace-nowrap font-medium leading-none text-gray-300">
                    {item.nom}
                  </span>
                </div>
              ))
            }
          </div>
        </div>
      </div>

      <div data-skills-progress class="mt-24">
        <h3 class="mb-12 text-2xl font-bold text-white">Savoir-faire</h3>

        <div class="flex flex-col gap-8">
          <div data-skill-row data-target="85" class="flex flex-col gap-3">
            <div class="flex items-start justify-between gap-6">
              <h4 class="text-lg font-semibold text-white">UX/UI Designer</h4>
              <div class="flex flex-col items-end">
                <span
                  data-skill-value
                  class="text-sm font-medium text-[#d019d0]">0%</span
                >
                <span
                  class="mt-1 h-2 w-2 rounded-full bg-[#d019d0] animate-pulse"
                ></span>
              </div>
            </div>
            <p class="text-xs text-gray-500">Figma · Photoshop · Illustrator</p>
            <div class="h-1.5 overflow-hidden rounded-full bg-white/10">
              <div
                data-skill-bar
                class="h-full w-0 rounded-full"
                style="background: linear-gradient(90deg, #d019d0, #9333ea);"
              >
              </div>
            </div>
          </div>

          <div data-skill-row data-target="70" class="flex flex-col gap-3">
            <div class="flex items-start justify-between gap-6">
              <h4 class="text-lg font-semibold text-white">Web Developer</h4>
              <div class="flex flex-col items-end">
                <span
                  data-skill-value
                  class="text-sm font-medium text-[#1974d1]">0%</span
                >
                <span
                  class="mt-1 h-2 w-2 rounded-full bg-[#1974d1] animate-pulse"
                ></span>
              </div>
            </div>
            <p class="text-xs text-gray-500">
              Astro · TailwindCSS · JavaScript · HTML/CSS
            </p>
            <div class="h-1.5 overflow-hidden rounded-full bg-white/10">
              <div
                data-skill-bar
                class="h-full w-0 rounded-full"
                style="background: linear-gradient(90deg, #1974d1, #06b6d4);"
              >
              </div>
            </div>
          </div>

          <div data-skill-row data-target="90" class="flex flex-col gap-3">
            <div class="flex items-start justify-between gap-6">
              <h4 class="text-lg font-semibold text-white">
                Digital Communication
              </h4>
              <div class="flex flex-col items-end">
                <span
                  data-skill-value
                  class="text-sm font-medium text-[#7c3aed]">0%</span
                >
                <span
                  class="mt-1 h-2 w-2 rounded-full bg-[#7c3aed] animate-pulse"
                ></span>
              </div>
            </div>
            <p class="text-xs text-gray-500">
              Premiere Pro · After Effects · TikTok · Stratégie
            </p>
            <div class="h-1.5 overflow-hidden rounded-full bg-white/10">
              <div
                data-skill-bar
                class="h-full w-0 rounded-full"
                style="background: linear-gradient(90deg, #7c3aed, #d019d0);"
              >
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Mes projets -->
  <section id="projects" class="py-32 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-8">
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6">
          <span class="text-white">MES </span><span class="neon-pink"
            >PROJETS</span
          >
        </h2>
        <p class="text-base text-gray-500 mb-16">
          Une sélection de projets mêlant design, développement et stratégie
          créative.
        </p>
      </div>

      <div data-projects-grid class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <article
          data-project-card
          class="group relative h-[380px] md:h-[480px] overflow-hidden rounded-3xl"
          style="opacity: 0;"
        >
          <div
            class="absolute inset-0 z-0 transition-transform duration-700 ease-out group-hover:scale-110"
          >
            <div
              class="relative h-full w-full bg-gradient-to-br from-teal-500 via-emerald-400 to-green-300"
            >
              <div
                class="absolute inset-0 flex items-center justify-center p-6"
              >
                <div
                  class="w-full max-w-[260px] rounded-2xl border border-white/35 bg-white/20 p-4 backdrop-blur-sm"
                >
                  <p
                    class="mb-3 text-center text-4xl text-white/95"
                    style="font-family: 'Brush Script MT', cursive;"
                  >
                    Planning
                  </p>
                  <div class="space-y-2">
                    <div class="h-3 w-4/5 rounded-md bg-pink-400/80"></div>
                    <div class="h-3 w-3/5 rounded-md bg-cyan-300/80"></div>
                    <div class="h-3 w-full rounded-md bg-emerald-100/80"></div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div
            class="absolute bottom-0 left-0 right-0 z-10 h-[40%] bg-gradient-to-t from-black/85 to-transparent"
          >
            <div class="absolute bottom-0 left-0 p-6">
              <p class="text-xs text-gray-500 font-mono">01</p>
              <p class="text-lg font-bold text-white">Planning Photoshop</p>
            </div>
          </div>

          <div
            class="project-hover-overlay absolute inset-0 z-20 flex translate-y-5 flex-col justify-end bg-gradient-to-t from-black/95 to-black/30 p-6 opacity-0 transition-all duration-[400ms] [transition-timing-function:cubic-bezier(0.4,0,0.2,1)] group-hover:translate-y-0 group-hover:opacity-100"
          >
            <div class="mb-3 flex flex-wrap gap-2">
              <span
                class="inline-flex items-center rounded-full border border-[#31A8FF]/30 bg-[#31A8FF]/10 px-2.5 py-1 text-xs font-medium text-[#31A8FF]"
                >Photoshop</span
              >
              <span
                class="inline-flex items-center rounded-full border border-[#FF9A00]/30 bg-[#FF9A00]/10 px-2.5 py-1 text-xs font-medium text-[#FF9A00]"
                >Illustrator</span
              >
            </div>
            <h3 class="text-xl font-bold text-white">Planning Photoshop</h3>
            <p class="project-desc-clamp text-sm text-gray-300">
              Série de maquettes pour une application de gestion de projets,
              conçues avec Photoshop pour des interfaces modernes et intuitives.
            </p>
            <a
              href="/Projets"
