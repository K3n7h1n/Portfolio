<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  // Enregistrer le plugin ScrollTrigger
  gsap.registerPlugin(ScrollTrigger);

  // Animation au scroll (Intersection Observer) pour les autres sections
  // On utilise un seuil bas (0.05 au lieu de 0.2) pour que les grands éléments comme skills-grid 
  // puissent déclencher l'animation même sur les petits écrans mobiles.
  const observerOptions = {
    threshold: 0.05,
    rootMargin: "0px 0px -50px 0px",
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        setTimeout(() => {
          entry.target.classList.add("animate-fade-in");
        }, 50);
        observer.unobserve(entry.target);
      }
    });
  }, observerOptions);

  // Observer tous les éléments avec la classe scroll-reveal
  document.addEventListener("DOMContentLoaded", () => {
    const elements = document.querySelectorAll(".scroll-reveal");
    elements.forEach((el, index) => {
      if (el instanceof HTMLElement) {
        el.style.transitionDelay = `${index * 0.1}s`;
      }
      observer.observe(el);
    });

    // Smooth scroll pour les liens d'ancrage
    document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
      anchor.addEventListener("click", function (e: Event) {
        e.preventDefault();
        const href = (e.currentTarget as HTMLAnchorElement).getAttribute(
          "href",
        );
        if (href) {
          const target = document.querySelector(href);
          if (target) {
            target.scrollIntoView({
              behavior: "smooth",
              block: "start",
            });
          }
        }
      });
    });

    // Animation de la timeline
    animateTimeline();

    // Initialiser l'effet de parallaxe GSAP pour la section "Mes passions"
    initPassionsParallax();

    // Gérer les contrôles vidéo personnalisés
    initVideoControls();
  });

  function animateTimeline() {
    const timeline = document.querySelector(".timeline-wave");
    if (timeline) {
      let position = 0;
      setInterval(() => {
        position += 1;
        (timeline as HTMLElement).style.backgroundPosition = `${position}px 0`;
      }, 50);
    }
  }

  /**
   * 🎥 Gestion des contrôles vidéo personnalisés
   */
  function initVideoControls() {
    // Boutons de son
    const soundButtons = document.querySelectorAll(".video-sound-btn");
    soundButtons.forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        const videoId = (btn as HTMLElement).getAttribute("data-video");
        const video = document.querySelector(
          `[data-video-id="${videoId}"]`,
        ) as HTMLVideoElement;
        const soundOff = btn.querySelector(".sound-off") as HTMLElement;
        const soundOn = btn.querySelector(".sound-on") as HTMLElement;

        if (video) {
          video.muted = !video.muted;
          if (soundOff && soundOn) {
            soundOff.classList.toggle("hidden");
            soundOn.classList.toggle("hidden");
          }
        }
      });
    });

    // Boutons plein écran
    const fullscreenButtons = document.querySelectorAll(
      ".video-fullscreen-btn",
    );
    fullscreenButtons.forEach((btn) => {
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        const videoId = (btn as HTMLElement).getAttribute("data-video");
        const video = document.querySelector(
          `[data-video-id="${videoId}"]`,
        ) as HTMLVideoElement;

        if (video) {
          if (video.requestFullscreen) {
            video.requestFullscreen();
          } else if ((video as any).webkitRequestFullscreen) {
            (video as any).webkitRequestFullscreen();
          } else if ((video as any).mozRequestFullScreen) {
            (video as any).mozRequestFullScreen();
          } else if ((video as any).msRequestFullscreen) {
            (video as any).msRequestFullscreen();
          }
        }
      });
    });
  }

  /**
   * 🎬 Animation GSAP pour la section "Mes passions"
   *
   * Phase 0 : Le texte est invisible jusqu'à ce qu'on arrive à la section
   * Phase 1 : Le texte apparaît quand on arrive à la section
   * Phase 2 : Au scroll, le texte disparaît (fade + déplacement vers le haut)
   * Phase 3 : Les vidéos apparaissent en fond avec effet de parallaxe
   */
  function initPassionsParallax() {
    const passionsSection = document.querySelector<HTMLElement>("#passions");
    const introPanel = document.querySelector<HTMLElement>("#passions-intro-panel");
    const chapters = gsap.utils.toArray<HTMLElement>("#passions .passion-chapter");

    if (!passionsSection || !introPanel || chapters.length === 0) {
      console.warn("Section Passions : éléments manquants pour l'animation GSAP");
      return;
    }

    const isMobile = window.matchMedia("(max-width: 768px)").matches;

    passionsSection.style.setProperty(
      "min-height",
      "400vh",
      "important",
    );
    passionsSection.style.setProperty("padding", "0", "important");

    gsap.fromTo(
      introPanel,
      {
        autoAlpha: 1,
        y: 0,
      },
      {
        autoAlpha: 0,
        y: -50,
        ease: "none",
        scrollTrigger: {
          trigger: passionsSection,
          start: "top top",
          end: "10% top",
          scrub: 1,
        },
      },
    );

    chapters.forEach((chapter) => {
      const numberEl = chapter.querySelector<HTMLElement>("[data-el='number']");
      const tagEl = chapter.querySelector<HTMLElement>("[data-el='tag']");
      const titleEl = chapter.querySelector<HTMLElement>("[data-el='title']");
      const descriptionEl = chapter.querySelector<HTMLElement>("[data-el='description']");
      const progressEl = chapter.querySelector<HTMLElement>("[data-el='progress']");
      const textWrapEl = chapter.querySelector<HTMLElement>("[data-el='text']");
      const mediaWrapEl = chapter.querySelector<HTMLElement>("[data-el='media']");
      const phoneFrameEl = chapter.querySelector<HTMLElement>("[data-el='phone']");

      const triggerConfig = {
        trigger: chapter,
        start: "top center",
        end: "bottom center",
        scrub: 1,
      };

      if (numberEl) {
        gsap.fromTo(
          numberEl,
          {
            autoAlpha: 0,
            y: isMobile ? 0 : 30,
          },
          {
            autoAlpha: 1,
            y: 0,
            ease: "none",
            scrollTrigger: triggerConfig,
          },
        );
      }

      if (tagEl) {
        gsap.fromTo(
          tagEl,
          {
            autoAlpha: 0,
            y: isMobile ? 0 : 18,
          },
          {
            autoAlpha: 1,
            y: 0,
            delay: isMobile ? 0 : 0.08,
            ease: "none",
            scrollTrigger: triggerConfig,
          },
        );
      }

      if (titleEl) {
        gsap.fromTo(
          titleEl,
          {
            autoAlpha: 0,
            x: isMobile ? 0 : -60,
          },
          {
            autoAlpha: 1,
            x: 0,
            ease: "none",
            scrollTrigger: triggerConfig,
          },
        );
      }

      if (descriptionEl) {
        gsap.fromTo(
          descriptionEl,
          {
            autoAlpha: 0,
            y: isMobile ? 0 : 14,
          },
          {
            autoAlpha: 1,
            y: 0,
            delay: isMobile ? 0 : 0.14,
            ease: "none",
            scrollTrigger: triggerConfig,
          },
        );
      }

      if (progressEl) {
        gsap.fromTo(
          progressEl,
          {
            width: "0%",
          },
          {
            width: "100%",
            ease: "none",
            scrollTrigger: triggerConfig,
          },
        );
      }

      if (phoneFrameEl) {
        gsap.fromTo(
          phoneFrameEl,
          isMobile
            ? {
                autoAlpha: 0,
              }
            : {
                autoAlpha: 0,
                scale: 0.85,
                rotate: -3,
              },
          isMobile
            ? {
                autoAlpha: 1,
                ease: "none",
                scrollTrigger: triggerConfig,
              }
            : {
                autoAlpha: 1,
                scale: 1,
                rotate: 0,
                ease: "none",
                scrollTrigger: triggerConfig,
              },
        );
      }

      if (textWrapEl && mediaWrapEl && !isMobile) {
        ScrollTrigger.create({
          trigger: chapter,
          start: "top center",
          end: "bottom center",
          onLeave: () => {
            gsap.to(textWrapEl, {
              y: -80,
              autoAlpha: 0,
              duration: 0.5,
              ease: "power2.out",
              overwrite: "auto",
            });
            gsap.to(mediaWrapEl, {
              y: 60,
              autoAlpha: 0,
              duration: 0.4,
              ease: "power2.out",
              overwrite: "auto",
            });
          },
          onEnterBack: () => {
            gsap.to(textWrapEl, {
              y: 0,
              autoAlpha: 1,
              duration: 0.45,
              ease: "power2.out",
              overwrite: "auto",
            });
            gsap.to(mediaWrapEl, {
              y: 0,
              autoAlpha: 1,
              duration: 0.35,
              ease: "power2.out",
              overwrite: "auto",
            });
          },
        });
      }
    });
  }
</script>

<style>
  /* Styles pour la page À propos */

  /* Animation de la timeline */
  .timeline-wave {
    background: linear-gradient(
      90deg,
      #d019d0 0%,
      #1974d1 25%,
      #d019d0 50%,
      #1974d1 75%,
      #d019d0 100%
    );
    background-size: 200% 100%;
    animation: waveFlow 3s linear infinite;
  }

  @keyframes waveFlow {
    0% {
      background-position: 0% 0%;
    }
    100% {
      background-position: 200% 0%;
    }
  }

  /* Styles des cartes timeline */
  .timeline-card {
    position: relative;
  }

  .timeline-card::before {
    content: "";
    position: absolute;
    top: -20px;
    left: 50%;
    transform: translateX(-50%);
    width: 16px;
    height: 16px;
    background: linear-gradient(135deg, #d019d0, #1974d1);
    border-radius: 50%;
    box-shadow: 0 0 20px rgba(208, 25, 208, 0.6);
    display: none;
  }

  @media (min-width: 768px) {
    .timeline-card::before {
      display: block;
    }
  }

  /* Grid responsive pour les compétences */
  .skills-grid {
    display: grid;
    grid-auto-flow: dense;
  }

  /* ===== STYLES POUR LA SECTION "MES PASSIONS" ===== */

  /* Section principale avec hauteur étendue pour le scroll */
  #passions {
    position: relative;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.9) 0%,
      rgba(10, 5, 20, 0.95) 50%,
      rgba(0, 0, 0, 0.9) 100%
    );
  }

  /* Forcer le format vertical (9:16) des vidéos en plein écran */
  .video-player:fullscreen {
    width: auto !important;
    height: 100% !important;
    max-width: 56.25vh; /* 9/16 * 100vh pour garder le ratio */
    margin: 0 auto;
    object-fit: contain;
  }

  .video-player:-webkit-full-screen {
    width: auto !important;
    height: 100% !important;
    max-width: 56.25vh;
    margin: 0 auto;
    object-fit: contain;
  }

  .video-player:-moz-full-screen {
    width: auto !important;
    height: 100% !important;
    max-width: 56.25vh;
    margin: 0 auto;
    object-fit: contain;
  }

  .video-player:-ms-fullscreen {
    width: auto !important;
    height: 100% !important;
    max-width: 56.25vh;
    margin: 0 auto;
    object-fit: contain;
  }

  /* Animation supplémentaire pour les éléments */
  @media (prefers-reduced-motion: no-preference) {
    .scroll-reveal {
      animation-play-state: running;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-reveal,
    .parallax-layer,
    #passions-text-container,
    #passions-videos-container {
      animation: none !important;
      transition: none !important;
      transform: none !important;
    }
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .timeline-card::before {
      display: none;
    }

    .skills-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
