---
import Layout from '../../layouts/Layout.astro';
import pb from '../../utils/pb';
import type { ProjetsResponse } from '../../utils/pocketbase-types';

// Récupérer le slug depuis les paramètres
const { slug } = Astro.params;

// Récupérer le projet depuis PocketBase
let projet: ProjetsResponse;

let prevProjet: ProjetsResponse | null = null;
let nextProjet: ProjetsResponse | null = null;

try {
	const tousLesProjets = await pb.collection('projets').getFullList({
		filter: 'afficher = true',
		sort: 'ordre_affichage',
	});
	
	const currentIndex = tousLesProjets.findIndex(p => p.slug === slug);
	
	if (currentIndex === -1) {
		return Astro.redirect('/Projets');
	}
	
	projet = tousLesProjets[currentIndex];
	prevProjet = currentIndex > 0 ? tousLesProjets[currentIndex - 1] : null;
	nextProjet = currentIndex < tousLesProjets.length - 1 ? tousLesProjets[currentIndex + 1] : null;
} catch (e) {
	console.error('Erreur lors de la récupération des projets:', e);
	return Astro.redirect('/Projets');
}

const getCategoryLabel = (type: string) => {
	switch (type) {
		case 'design': return '🎨 Design Graphique';
		case 'web': return '💻 Développement Web';
		case 'communication': return '📱 Communication Digitale';
		case 'video': return '🎬 Vidéo';
		case 'autre': return '✨ Autre';
		default: return '✨ Projet';
	}
};

// Construire les URLs des images avec pb.files.getUrl()
const imageUrl = pb.files.getUrl(projet, projet.photo_principale || '');
const galerieUrls = projet.galerie_photos ? projet.galerie_photos.map((photo: string) => 
	pb.files.getUrl(projet, photo)
) : [];

// Parser les informations JSON
let infos: any = {};
try {
	infos = typeof projet.informations === 'string' ? JSON.parse(projet.informations) : projet.informations || {};
} catch {
	infos = {};
}

// Définir le titre de la page avec une valeur par défaut
const projetTitre = projet.titre || projet.nom || 'Projet';
const pageTitle = `${projetTitre} - Projets`;
const pageDescription = projet.description_courte || 'Découvrez ce projet';
---

<Layout title={pageTitle} description={pageDescription}>
	<!-- Hero du projet -->
	<section class="min-h-screen px-4 py-20">
		<div class="max-w-7xl mx-auto">
			<!-- Bouton retour -->
			<div class="mb-8 scroll-reveal">
				<a href="/Projets" class="inline-flex items-center gap-2 text-primary-pink hover:text-primary-pink/80 transition-colors">
					<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
					</svg>
					Retour aux projets
				</a>
			</div>

			<!-- Titre et infos principales -->
			<div class="text-center mb-16 scroll-reveal">
				<div class="inline-flex items-center gap-2 mb-4 px-4 py-2 rounded-full bg-primary-pink/20 border border-primary-pink/30">
					<span class="text-primary-pink font-semibold">
						{getCategoryLabel(projet.type)}
					</span>
				</div>
				
				<h1 class="text-5xl md:text-6xl lg:text-7xl font-bold mb-6">
					<span class="neon-pink">{projetTitre}</span>
				</h1>
				
				<p class="text-xl md:text-2xl text-gray-300 max-w-3xl mx-auto">
					{projet.description_courte}
				</p>
			</div>

			<!-- Image principale avec effet -->
			<div class="relative mb-20 scroll-reveal">
				<div class="absolute inset-0 bg-gradient-to-br from-primary-pink/20 to-primary-blue/20 blur-3xl"></div>
				<div class="relative rounded-3xl overflow-hidden border-2 border-primary-pink/30 hover:border-primary-pink transition-all duration-300 shadow-2xl">
					<img 
						src={imageUrl} 
						alt={projet.titre}
						class="w-full h-auto max-h-[600px] object-cover"
					/>
				</div>
			</div>

			<!-- Grille informations et description -->
			<div class="grid lg:grid-cols-3 gap-12 mb-20">
				<!-- Colonne gauche - Informations -->
				<div class="lg:col-span-1 space-y-6 scroll-reveal">
					<!-- Card Informations -->
					<div class="card bg-gradient-to-br from-gray-900/50 to-black/50 backdrop-blur-sm border border-primary-pink/30 hover:border-primary-pink transition-all">
						<div class="card-body p-8">
							<h3 class="text-2xl font-bold text-primary-pink mb-6 flex items-center gap-3">
								<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
								</svg>
								Informations
							</h3>
							<div class="space-y-5">
								{infos.duree && (
									<div class="info-item">
										<span class="info-label">Durée</span>
										<span class="info-value">{infos.duree}</span>
									</div>
								)}
								{infos.equipe && (
									<div class="info-item">
										<span class="info-label">Équipe</span>
										<span class="info-value">{infos.equipe}</span>
									</div>
								)}
								{infos.contexte && (
									<div class="info-item">
										<span class="info-label">Contexte</span>
										<span class="info-value">{infos.contexte}</span>
									</div>
								)}
								{infos.role && (
									<div class="info-item">
										<span class="info-label">Rôle</span>
										<span class="info-value">{infos.role}</span>
									</div>
								)}
								{projet.client && (
									<div class="info-item">
										<span class="info-label">Client</span>
										<span class="info-value">{projet.client}</span>
									</div>
								)}
								{projet.date_realisation && (
									<div class="info-item">
										<span class="info-label">Date</span>
										<span class="info-value">
											{new Date(projet.date_realisation).toLocaleDateString('fr-FR', { month: 'long', year: 'numeric' })}
										</span>
									</div>
								)}
							</div>
						</div>
					</div>

					<!-- Card Technologies -->
					{projet.technologies && projet.technologies.length > 0 && (
						<div class="card bg-gradient-to-br from-gray-900/50 to-black/50 backdrop-blur-sm border border-primary-blue/30 hover:border-primary-blue transition-all">
							<div class="card-body p-8">
								<h3 class="text-2xl font-bold text-primary-blue mb-6 flex items-center gap-3">
									<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
									</svg>
									Technologies
								</h3>
								<div class="flex flex-wrap gap-3">
									{projet.technologies.map((tech: string) => (
										<span class="px-4 py-2 bg-primary-blue/20 text-primary-blue border border-primary-blue/30 rounded-lg text-base font-medium hover:bg-primary-blue/30 transition-all">
											{tech}
										</span>
									))}
								</div>
							</div>
						</div>
					)}

					<!-- Card Liens -->
					<div class="card bg-gradient-to-br from-gray-900/50 to-black/50 backdrop-blur-sm border border-primary-pink/30 hover:border-primary-pink transition-all">
						<div class="card-body p-8">
							<h3 class="text-2xl font-bold text-primary-pink mb-6 flex items-center gap-3">
								<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path>
								</svg>
								Liens
							</h3>
							<div class="space-y-4">
								{projet.lien_figma && (
									<a 
										href={projet.lien_figma} 
										target="_blank"
										class="flex items-center gap-3 text-gray-300 hover:text-primary-pink transition-colors text-base p-3 rounded-lg hover:bg-primary-pink/10"
									>
										<svg class="w-6 h-6 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
											<path d="M12 12a4 4 0 1 1 8 0 4 4 0 0 1-8 0zM8 0a4 4 0 0 0 0 8h4V0H8zm0 8a4 4 0 1 0 0 8h4V8H8zm0 8a4 4 0 0 0 0 8 4 4 0 0 0 4-4v-4H8z"/>
										</svg>
										<span>Voir sur Figma</span>
									</a>
								)}
								{projet.lien_demo && (
									<a 
										href={projet.lien_demo} 
										target="_blank"
										class="flex items-center gap-3 text-gray-300 hover:text-primary-pink transition-colors text-base p-3 rounded-lg hover:bg-primary-pink/10"
									>
										<svg class="w-6 h-6 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
										</svg>
										<span>Voir la démo</span>
									</a>
								)}
								{projet.lien_github && (
									<a 
										href={projet.lien_github} 
										target="_blank"
										class="flex items-center gap-3 text-gray-300 hover:text-primary-pink transition-colors text-base p-3 rounded-lg hover:bg-primary-pink/10"
									>
										<svg class="w-6 h-6 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
											<path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
										</svg>
										<span>Voir sur GitHub</span>
									</a>
								)}
								{projet.lien_divers && (
									<a 
										href={projet.lien_divers} 
										target="_blank"
										class="flex items-center gap-3 text-gray-300 hover:text-primary-pink transition-colors text-base p-3 rounded-lg hover:bg-primary-pink/10"
									>
										<svg class="w-6 h-6 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path>
										</svg>
										<span>Voir la vidéo / Autre lien</span>
									</a>
								)}
							</div>
						</div>
					</div>
				</div>

				<!-- Colonne droite - Description et détails -->
				<div class="lg:col-span-2 space-y-8 scroll-reveal" style="animation-delay: 0.2s;">
					<!-- Description complète -->
					<div class="prose prose-invert max-w-none">
						<div class="bg-gradient-to-br from-gray-900/50 to-black/50 backdrop-blur-sm border border-primary-pink/30 rounded-2xl p-8">
							<h2 class="text-3xl font-bold text-white mb-6 flex items-center gap-2">
								<svg class="w-8 h-8 text-primary-pink" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
								</svg>
								Description du projet
							</h2>
							<div class="text-gray-300 leading-relaxed">
								<Fragment set:html={projet.description_complete} />
							</div>
						</div>
					</div>

					<!-- Détails (si présents) -->
					{projet.details && (
						<div class="prose prose-invert max-w-none">
							<div class="bg-gradient-to-br from-gray-900/50 to-black/50 backdrop-blur-sm border border-primary-blue/30 rounded-2xl p-8">
								<h2 class="text-3xl font-bold text-white mb-6 flex items-center gap-2">
									<svg class="w-8 h-8 text-primary-blue" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path>
									</svg>
									Détails techniques
								</h2>
								<div class="text-gray-300 leading-relaxed">
									<Fragment set:html={projet.details} />
								</div>
							</div>
						</div>
					)}
				</div>
			</div>

			<!-- Galerie d'images -->
			{galerieUrls.length > 0 && (
				<div class="mb-20 scroll-reveal">
					<h2 class="text-3xl md:text-4xl font-bold text-center mb-12">
						<span class="text-white">GALERIE </span><span class="neon-pink">D'IMAGES</span>
					</h2>
					<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 items-start">
						{galerieUrls.map((url: string, index: number) => (
							<div class="gallery-item rounded-2xl overflow-hidden border-2 border-primary-pink/20 hover:border-primary-pink transition-all cursor-pointer">
								<img 
									src={url} 
									alt={`${projet.titre} - Image ${index + 1}`}
									class="w-full h-auto object-contain hover:scale-105 transition-transform duration-500 pointer-events-none"
								/>
							</div>
						))}
					</div>
				</div>
			)}

			<!-- Navigation Projets Voisins (Prev/Next) -->
			<div class="grid md:grid-cols-2 gap-6 mb-16 scroll-reveal">
				{prevProjet ? (
					<a href={`/projets/${prevProjet.slug}`} class="group relative overflow-hidden rounded-2xl border border-primary-pink/20 bg-gray-900/50 p-6 transition-all hover:border-primary-pink hover:bg-gray-800/50 flex items-center gap-4">
						<div class="w-20 h-20 md:w-24 md:h-24 shrink-0 overflow-hidden rounded-xl">
							<img src={pb.files.getUrl(prevProjet, prevProjet.photo_principale || '')} alt={prevProjet.titre || prevProjet.nom} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
						</div>
						<div class="flex-1">
							<div class="text-xs md:text-sm text-gray-400 mb-1 flex items-center gap-2">
								<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
								</svg>
								Projet précédent
							</div>
							<h3 class="text-lg md:text-xl font-bold text-white group-hover:text-primary-pink transition-colors line-clamp-2">{prevProjet.titre || prevProjet.nom}</h3>
							<div class="text-xs md:text-sm text-primary-pink/80 mt-1">{getCategoryLabel(prevProjet.type)}</div>
						</div>
					</a>
				) : <div class="hidden md:block"></div>}

				{nextProjet ? (
					<a href={`/projets/${nextProjet.slug}`} class="group relative overflow-hidden rounded-2xl border border-primary-blue/20 bg-gray-900/50 p-6 transition-all hover:border-primary-blue hover:bg-gray-800/50 flex items-center gap-4 text-right justify-end">
						<div class="flex-1">
							<div class="text-xs md:text-sm text-gray-400 mb-1 flex items-center justify-end gap-2">
								Projet suivant
								<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
								</svg>
							</div>
							<h3 class="text-lg md:text-xl font-bold text-white group-hover:text-primary-blue transition-colors line-clamp-2">{nextProjet.titre || nextProjet.nom}</h3>
							<div class="text-xs md:text-sm text-primary-blue/80 mt-1">{getCategoryLabel(nextProjet.type)}</div>
						</div>
						<div class="w-20 h-20 md:w-24 md:h-24 shrink-0 overflow-hidden rounded-xl">
							<img src={pb.files.getUrl(nextProjet, nextProjet.photo_principale || '')} alt={nextProjet.titre || nextProjet.nom} class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-110" />
						</div>
					</a>
				) : <div class="hidden md:block"></div>}
			</div>

			<!-- Navigation vers autres projets -->
			<div class="text-center scroll-reveal">
				<a href="/Projets" class="btn btn-primary btn-lg btn-neon">
					<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path>
					</svg>
					Voir tous les projets
				</a>
			</div>
		</div>
	</section>

	<!-- LIGHTBOX HTML — div classique pour éviter les doublons du dialog natif -->
	<div id="lightbox" class="lightbox-dialog" aria-label="Visionneuse d'images" aria-modal="true" role="dialog" tabindex="-1">
		<!-- Backdrop cliquable pour fermer -->
		<div id="lightbox-backdrop" class="lightbox-backdrop"></div>

		<div id="lightbox-container" class="lightbox-container">
			<img id="lightbox-img" src="" alt="" class="lightbox-image" />
			<div id="lightbox-counter" class="lightbox-counter">
				<span id="lightbox-current">1</span> / <span id="lightbox-total">1</span>
			</div>
		</div>

		<button id="lightbox-close" class="lightbox-close" aria-label="Fermer">
			<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
			</svg>
		</button>

		<button id="lightbox-prev" class="lightbox-nav lightbox-nav-prev" aria-label="Image précédente">
			<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
			</svg>
		</button>

		<button id="lightbox-next" class="lightbox-nav lightbox-nav-next" aria-label="Image suivante">
			<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
			</svg>
		</button>

		<div id="lightbox-thumbs" class="lightbox-thumbs"></div>
	</div>
</Layout>

<script>
	import { gsap } from 'gsap';

	// ===== Animation au scroll =====
	const scrollObserver = new IntersectionObserver((entries) => {
		entries.forEach(entry => {
			if (entry.isIntersecting) {
				setTimeout(() => entry.target.classList.add('animate-fade-in'), 50);
				scrollObserver.unobserve(entry.target);
			}
		});
	}, { threshold: 0.2, rootMargin: '0px 0px -50px 0px' });

	function initPage() {
		document.querySelectorAll('.scroll-reveal').forEach((el, index) => {
			if (el instanceof HTMLElement) el.style.transitionDelay = `${index * 0.1}s`;
			scrollObserver.observe(el);
		});

		// ===== LIGHTBOX =====
		// Remplacement du dialog natif par un div pour éviter les conflits CSS/DaisyUI (doublon de fenêtres)
		const lightboxNodes = Array.from(document.querySelectorAll<HTMLDivElement>('#lightbox'));
		const lightbox = lightboxNodes.pop() ?? null;
		lightboxNodes.forEach((node) => node.remove());

		const lightboxImg     = lightbox?.querySelector<HTMLImageElement>('#lightbox-img') ?? null;
		const lightboxBackdrop        = lightbox?.querySelector('#lightbox-backdrop');
		const lightboxClose           = lightbox?.querySelector('#lightbox-close');
		const lightboxPrev            = lightbox?.querySelector<HTMLButtonElement>('#lightbox-prev') ?? null;
		const lightboxNext            = lightbox?.querySelector<HTMLButtonElement>('#lightbox-next') ?? null;
		const lightboxCurrent         = lightbox?.querySelector('#lightbox-current');
		const lightboxTotal           = lightbox?.querySelector('#lightbox-total');
		const lightboxThumbsContainer = lightbox?.querySelector('#lightbox-thumbs');
		const lightboxContainer       = lightbox?.querySelector('#lightbox-container');

		if (!lightbox || !lightboxImg) return;
		if (lightbox.dataset.init === 'true') return;
		lightbox.dataset.init = 'true';

		lightbox.style.display = 'none';
		document.body.classList.remove('lightbox-is-open');
		lightboxImg.src = '';

		const images: { src: string; alt: string }[] = [];
		let currentIndex = 0;

		// Construire images + thumbnails
		if (lightboxThumbsContainer) lightboxThumbsContainer.innerHTML = '';

		const pageRoot = lightbox.closest('main') ?? document;

		pageRoot.querySelectorAll('.gallery-item').forEach((item, index) => {
			const img = item.querySelector('img') as HTMLImageElement | null;
			if (!img) return;

			images.push({ src: img.src, alt: img.alt });

			const thumb = document.createElement('img');
			thumb.src = img.src;
			thumb.alt = img.alt;
			thumb.className = 'lightbox-thumb';
			thumb.dataset.index = String(index);
			thumb.addEventListener('click', (e) => { e.stopPropagation(); openLightbox(index); });
			lightboxThumbsContainer?.appendChild(thumb);

			item.addEventListener('click', (e) => { e.stopPropagation(); openLightbox(index); });
		});

		if (images.length <= 1) {
			lightbox.setAttribute('data-single', 'true');
		} else {
			lightbox.removeAttribute('data-single');
		}
		if (lightboxTotal) lightboxTotal.textContent = String(images.length);

		// ---- Fonctions ----

		function openLightbox(index: number) {
			currentIndex = index;
			lightboxImg!.src = images[index].src;
			lightboxImg!.alt = images[index].alt;
			updateUI();

			// Affichage avec style flex au lieu de showModal() pour éviter les conflits
			lightbox!.style.display = 'flex';
			document.body.classList.add('lightbox-is-open');

			gsap.killTweensOf([lightbox, lightboxContainer]);
			gsap.fromTo(lightbox,  { opacity: 0 }, { opacity: 1, duration: 0.3, ease: 'power2.out' });
			gsap.fromTo(lightboxContainer,
				{ scale: 0.82, opacity: 0, y: 20 },
				{ scale: 1,    opacity: 1, y: 0,  duration: 0.4, ease: 'back.out(1.4)', delay: 0.05 }
			);
		}

		function closeLightbox() {
			gsap.to(lightboxContainer, { scale: 0.88, opacity: 0, y: 10, duration: 0.25, ease: 'power2.in' });
			gsap.to(lightbox, {
				opacity: 0, duration: 0.3, ease: 'power2.in', delay: 0.05,
				onComplete: () => {
					lightbox!.style.display = 'none';
					document.body.classList.remove('lightbox-is-open');
					lightboxImg!.src = '';
				}
			});
		}

		function navigate(direction: number) {
			if (images.length <= 1) return;
			const newIndex = (currentIndex + direction + images.length) % images.length;
			const xFrom = direction > 0 ? 40 : -40;
			gsap.to(lightboxContainer, {
				opacity: 0, x: -xFrom, scale: 0.95, duration: 0.18, ease: 'power2.in',
				onComplete: () => {
					currentIndex = newIndex;
					lightboxImg!.src = images[newIndex].src;
					lightboxImg!.alt = images[newIndex].alt;
					updateUI();
					gsap.fromTo(lightboxContainer,
						{ opacity: 0, x: xFrom, scale: 0.95 },
						{ opacity: 1, x: 0,     scale: 1,    duration: 0.22, ease: 'power2.out' }
					);
				}
			});
		}

		function updateUI() {
			if (lightboxCurrent) lightboxCurrent.textContent = String(currentIndex + 1);
			if (lightboxPrev) lightboxPrev.disabled = false;
			if (lightboxNext) lightboxNext.disabled = false;
			lightboxThumbsContainer?.querySelectorAll('.lightbox-thumb').forEach((t, i) => {
				t.classList.toggle('active', i === currentIndex);
			});
			const active = lightboxThumbsContainer?.querySelector('.lightbox-thumb.active') as HTMLElement | null;
			active?.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
		}

		// ---- Event listeners ----
		lightboxClose?.addEventListener('click', closeLightbox);
		lightboxBackdrop?.addEventListener('click', closeLightbox);
		lightboxPrev?.addEventListener('click', () => navigate(-1));
		lightboxNext?.addEventListener('click', () => navigate(1));

		// Navigation clavier globale
		window.addEventListener('keydown', (e: KeyboardEvent) => {
			if (lightbox!.style.display !== 'flex') return;
			if (e.key === 'Escape')     { e.preventDefault(); closeLightbox(); }
			if (e.key === 'ArrowLeft')  navigate(-1);
			if (e.key === 'ArrowRight') navigate(1);
		});

		let touchStartX = 0;
		lightbox.addEventListener('touchstart', (e: TouchEvent) => { touchStartX = e.touches[0].clientX; }, { passive: true });
		lightbox.addEventListener('touchend',   (e: TouchEvent) => {
			const diff = touchStartX - e.changedTouches[0].clientX;
			if (Math.abs(diff) > 50) navigate(diff > 0 ? 1 : -1);
		}, { passive: true });
	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initPage);
	} else {
		initPage();
	}

	document.addEventListener('astro:page-load', initPage);
</script>

<style>
	/* ===== LIGHTBOX — dialog natif ===== */

	/* Reset du conteneur classique */
	.lightbox-dialog {
		position: fixed;
		inset: 0;
		margin: auto;
		padding: 0;
		border: none;
		background: transparent;
		max-width: 100vw;
		max-height: 100dvh;
		width: 100vw;
		height: 100dvh;
		display: none; /* caché par défaut */
		align-items: center;
		justify-content: center;
		z-index: 9999;
		opacity: 0; /* géré par GSAP */
	}

	/* Notre backdrop personnalisé — couvre tout le container */
	.lightbox-backdrop {
		position: absolute;
		inset: 0;
		background: rgba(0, 0, 0, 0.88);
		backdrop-filter: blur(8px);
		-webkit-backdrop-filter: blur(8px);
		z-index: 0;
	}

	/* Conteneur image — centre l'image avec une taille max limitée */
	.lightbox-container {
		position: relative;
		z-index: 10;
		display: flex;
		align-items: center;
		justify-content: center;
		max-width: min(88vw, 1200px);
		max-height: calc(100vh - 180px);
		max-height: calc(100dvh - 180px);
		margin: 0;
	}

	/* Image : proportions naturelles (contain), jamais déformée */
	.lightbox-image {
		display: block;
		max-width: min(88vw, 1200px);
		max-height: calc(100vh - 180px);
		max-height: calc(100dvh - 180px);
		width: auto;
		height: auto;
		object-fit: contain;
		flex-shrink: 0;
		border-radius: 12px;
		border: 1px solid rgba(208, 25, 208, 0.3);
		box-shadow:
			0 0 60px rgba(208, 25, 208, 0.2),
			0 0 80px rgba(25, 116, 209, 0.15),
			0 40px 80px rgba(0, 0, 0, 0.6);
	}

	.lightbox-close {
		position: fixed;
		top: 1.25rem;
		right: 1.25rem;
		z-index: 20;
		width: 44px;
		height: 44px;
		border-radius: 50%;
		background: rgba(255, 255, 255, 0.08);
		border: 1px solid rgba(255, 255, 255, 0.15);
		color: white;
		display: flex;
		align-items: center;
		justify-content: center;
		cursor: pointer;
		transition: background 0.2s, border-color 0.2s, transform 0.2s;
		backdrop-filter: blur(10px);
	}

	.lightbox-close:hover {
		background: rgba(208, 25, 208, 0.2);
		border-color: rgba(208, 25, 208, 0.5);
		transform: rotate(90deg);
	}

	.lightbox-nav {
		position: fixed;
		top: 50%;
		transform: translateY(-50%);
		z-index: 20;
		width: 52px;
		height: 52px;
		border-radius: 50%;
		background: rgba(255, 255, 255, 0.06);
		border: 1px solid rgba(255, 255, 255, 0.12);
		color: white;
		display: flex;
		align-items: center;
		justify-content: center;
		cursor: pointer;
		transition: all 0.2s;
		backdrop-filter: blur(10px);
	}

	.lightbox-nav:hover {
		background: rgba(208, 25, 208, 0.2);
		border-color: rgba(208, 25, 208, 0.5);
		transform: translateY(-50%) scale(1.1);
	}

	.lightbox-nav:disabled {
		opacity: 0.25;
		cursor: not-allowed;
		pointer-events: none;
	}

	.lightbox-nav-prev { left: 1.25rem; }
	.lightbox-nav-next { right: 1.25rem; }

	@media (min-width: 768px) {
		.lightbox-nav-prev { left: 2rem; }
		.lightbox-nav-next { right: 2rem; }
	}

	.lightbox-counter {
		position: absolute;
		bottom: -2rem;
		left: 50%;
		transform: translateX(-50%);
		font-size: 0.75rem;
		color: rgba(255, 255, 255, 0.4);
		font-family: monospace;
		white-space: nowrap;
	}

	.lightbox-thumbs {
		position: fixed;
		bottom: 1.25rem;
		left: 50%;
		transform: translateX(-50%);
		z-index: 20;
		display: flex;
		gap: 8px;
		padding: 8px;
		background: rgba(0, 0, 0, 0.5);
		border-radius: 12px;
		backdrop-filter: blur(10px);
		border: 1px solid rgba(255, 255, 255, 0.08);
		max-width: 90vw;
		overflow-x: auto;
	}

	.lightbox-thumb {
		width: 48px;
		height: 48px;
		border-radius: 6px;
		object-fit: cover;
		cursor: pointer;
		opacity: 0.45;
		border: 1.5px solid transparent;
		transition: all 0.2s;
		flex-shrink: 0;
	}

	.lightbox-thumb:hover {
		opacity: 0.75;
	}

	.lightbox-thumb.active {
		opacity: 1;
		border-color: #D019D0;
		box-shadow: 0 0 12px rgba(208, 25, 208, 0.4);
	}

	:global(body.lightbox-is-open) {
		overflow: hidden;
	}

	:global(body.lightbox-is-open nav) {
		z-index: 0 !important;
	}

	.lightbox-dialog[data-single="true"] .lightbox-nav,
	.lightbox-dialog[data-single="true"] .lightbox-thumbs,
	.lightbox-dialog[data-single="true"] .lightbox-counter {
		display: none;
	}

	/* Styles pour le contenu HTML riche */
	.prose {
		font-size: 1.125rem;
		line-height: 1.75;
	}

	.prose h3 {
		color: #D019D0;
		font-size: 1.5rem;
		font-weight: 700;
		margin-top: 2rem;
		margin-bottom: 1rem;
	}

	.prose p {
		margin-bottom: 1rem;
